<Window x:Class="TwoFactorAuth.Win.PasteUriDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="粘贴 otpauth URI" Height="200" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="整行 otpauth://totp/...（可从网站复制）" Margin="0,0,0,8"/>
        <TextBox x:Name="TxtUri" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="确定" Width="80" Margin="0,0,8,0" IsDefault="True" Click="Ok_OnClick"/>
            <Button Content="取消" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
